    <link rel="preload" href="/vanlogo.png" as="image" type="image/png" fetchpriority="high" />
    
    <!-- Fonts served locally via @fontsource (no external requests) -->
    
    <!-- Preconnect to main domain for faster resource loading -->
    <link rel="dns-prefetch" href="https://chrisyourmanwithavan.com" />
    <link rel="preconnect" href="https://chrisyourmanwithavan.com" crossorigin />
    
    <!-- Preconnect to Google Maps API -->
    <link rel="dns-prefetch" href="https://maps.googleapis.com" />
    <link rel="preconnect" href="https://maps.googleapis.com" />

