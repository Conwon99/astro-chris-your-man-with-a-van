    <link rel="apple-touch-icon" sizes="76x76" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="apple-touch-icon" sizes="72x72" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="apple-touch-icon" sizes="60x60" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="apple-touch-icon" sizes="57x57" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="mask-icon" href="https://chrisyourmanwithavan.com/vanlogo.png" color="#C4691F" />
    <meta name="msapplication-TileImage" content="https://chrisyourmanwithavan.com/vanlogo.png" />
    <meta name="msapplication-TileColor" content="#C4691F" />
    <meta name="theme-color" content="#C4691F" />
    
    <!-- Critical CSS - Inlined -->
    <style id="critical-css" is:inline>
      :root{--sunshine-yellow:51 85% 60%;--primary-orange:19 67% 49%;--dark-orange:19 67% 39%;--background:0 0% 0%;--foreground:0 0% 100%;--card:0 0% 10%;--card-foreground:0 0% 100%;--primary:19 67% 49%;--primary-foreground:0 0% 100%;--muted:0 0% 15%;--muted-foreground:0 0% 80%;--border:0 0% 20%;--radius:1rem}*{box-sizing:border-box;margin:0;padding:0;border:0}html{overflow-x:hidden;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}body{margin:0;padding:0;background-color:hsl(var(--background));color:hsl(var(--foreground));font-family:system-ui,-apple-system,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;line-height:1.5;overflow-x:hidden;-webkit-overflow-scrolling:touch}nav{position:fixed;top:0;width:100%;z-index:50;transition:all .3s ease-in-out}#hero{min-height:100vh;position:relative;display:flex;align-items:center;background-color:#000;overflow:hidden}#root{min-height:100vh}img{max-width:100%;height:auto;display:block}button{cursor:pointer;font-family:inherit}.font-display{font-family:'Outfit',system-ui,sans-serif}
