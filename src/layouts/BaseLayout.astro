<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Chris, Your Man with a Van" />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content={robots} />
    <meta name="language" content="English" />
    <meta name="geo.region" content="GB-AYS" />
    <meta name="geo.placename" content="Cumnock, Ayrshire, Scotland" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    
    <!-- Hreflang for UK targeting -->
    <link rel="alternate" hreflang="en-gb" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    
    <!-- Structured Data - LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    
    <!-- Structured Data - Organization (for Google Site Icon) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Chris, Your Man with a Van",
      "url": "https://chrisyourmanwithavan.com/",
      "logo": "https://chrisyourmanwithavan.com/vanlogo.png",
      "sameAs": [
        "https://www.facebook.com/chrisyourmanwithavankilmarnock",
        "https://g.page/r/CTXFEt51p7p3EBM"
      ]
    })} />
    
    <!-- Favicon - Using vanlogo as site icon for Google Search -->
    <!-- Primary icon - must be at least 112x112px for Google -->
    <link rel="icon" type="image/png" sizes="192x192" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="shortcut icon" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <!-- Apple Touch Icons -->
    <link rel="apple-touch-icon" sizes="180x180" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="https://chrisyourmanwithavan.com/vanlogo.png" />
    <link rel="apple-touch-icon" sizes="144x144" href="https://chrisyourmanwithavan.com/vanlogo.png" />
