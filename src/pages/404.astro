---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../index.css';
---

<BaseLayout
  title="404 - Page Not Found | Chris, Your Man with a Van"
  description="The page you're looking for doesn't exist. Return to Chris, Your Man with a Van homepage for professional van services and removals in Cumnock & Ayrshire."
  canonical="https://chrisyourmanwithavan.com/404"
  robots="noindex, nofollow"
>
  <div class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="text-center max-w-md mx-auto px-4">
      <h1 class="text-6xl font-bold text-[hsl(var(--primary-orange))] mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-[hsl(var(--asphalt-grey))] mb-4">Page Not Found</h2>
      <p class="text-lg text-[hsl(var(--asphalt-grey))] mb-8 leading-relaxed">
        Sorry, the page you're looking for doesn't exist. It might have been moved, deleted, or you entered the wrong URL.
      </p>
      
      <div class="space-y-4">
        <a 
          href="/" 
          class="inline-block bg-[hsl(var(--primary-orange))] text-white px-8 py-3 rounded-full font-semibold hover:opacity-90 transition-opacity"
        >
          Return to Homepage
        </a>
        
        <div class="text-sm text-[hsl(var(--asphalt-grey))]">
          <p class="mb-2">Or try these popular sections:</p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/#services" class="text-[hsl(var(--primary-orange))] hover:underline">Our Services</a>
            <a href="/#about" class="text-[hsl(var(--primary-orange))] hover:underline">About Chris</a>
            <a href="/#contact-form" class="text-[hsl(var(--primary-orange))] hover:underline">Get Quote</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>


