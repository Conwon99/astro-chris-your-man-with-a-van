export async function getStaticPaths() {
  const locations = [
    'cumnock',
    'ayr',
    'kilmarnock',
    'irvine',
    'troon',
    'prestwick',
    'kirkconnel',
    'sanquhar',
    'mossblown',
    'ardrossan',
    'dreghorn',
    'saltcoats',
    'beith',
    'stewarton',
    'patna',
    'dalmellington',
    'maybole',
    'newmilns',
    'darvel',
    'dalrymple',
    'galston',
    'girvan',
    'dalry',
    'kilwinning',
    'largs',
    'auchinleck',
    'mauchline',
  ];

  return locations.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const location = locationData[slug || ''] || locationData['cumnock'];
const locationSlug = slug || 'cumnock';
---

<BaseLayout
  title={getLocationHubTitle(location.name, locationSlug)}
  description={getLocationHubMeta(location.name, locationSlug)}
  canonical={`https://chrisyourmanwithavan.com/locations/${slug}`}
>
  <!-- BreadcrumbList schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chrisyourmanwithavan.com/" },
      { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://chrisyourmanwithavan.com/locations" },
      { "@type": "ListItem", "position": 3, "name": location.name, "item": `https://chrisyourmanwithavan.com/locations/${slug}` }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": `Chris, Your Man with a Van — ${location.name}`,
    "url": `https://chrisyourmanwithavan.com/locations/${slug}`,
    "telephone": "+447735852822",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "reviewCount": "77"
    },
    "areaServed": {
      "@type": "City",
      "name": location.name,
      "containedInPlace": { "@type": "AdministrativeArea", "name": "Ayrshire" }
    }
  })} />

  <LocationDetailComponent slug={slug} client:load />
</BaseLayout>

